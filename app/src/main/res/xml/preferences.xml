    </PreferenceCategory>

    <PreferenceCategory app:title="Безопасность">
        <Preference
            app:icon="@drawable/ic_lock"
            app:key="password_protection"
            app:summary="Защита приложения паролем"
            app:title="Парольная защита" />
    </PreferenceCategory>
    -->

    <PreferenceCategory app:title="О приложении">
        <Preference
            app:icon="@drawable/ic_info"
            app:key="about"
            app:summary="Версия и информация о разработчике"
            app:title="О программе" />

    </PreferenceCategory>
</PreferenceScreen>