            app:icon="@drawable/ic_backup"
            app:key="backup"
            app:summary="Сохранить копию базы данных на устройство"
            app:title="Создать резервную копию" />

        <Preference
            app:icon="@drawable/ic_restore"
            app:key="restore"
            app:summary="Восстановить данные из ранее сохранённой копии"
