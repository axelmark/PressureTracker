<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Данные пользователя">
        <Preference
            app:icon="@drawable/ic_person"
            app:key="user_data"
            app:summary="Настройте ваши личные данные"
            app:title="Управление профилем" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Уведомления">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:icon="@drawable/ic_notification"
            app:key="notifications_master_switch"
            app:summary="Глобальное управление уведомлениями"
            app:title="Разрешить уведомления" />

        <Preference
            app:dependency="notifications_master_switch"
            app:icon="@drawable/ic_settings"
            app:key="notification_settings"
            app:summary="Частота и время напоминаний"
            app:title="Настройка напоминаний" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Экспорт данных">
        <Preference
            app:icon="@drawable/ic_export"
            app:key="export_data"
            app:summary="Сохранение данных в файл"
            app:title="Экспорт в CSV/PDF" />
    </PreferenceCategory>

