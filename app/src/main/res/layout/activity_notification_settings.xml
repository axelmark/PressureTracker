<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceVariant">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimaryContainer">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/notification_settings"
            app:titleTextAppearance="?attr/textAppearanceHeadlineSmall"
            app:titleTextColor="?attr/colorOnPrimaryContainer"/>
    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_xlarge"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/spacing_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/notificationWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorErrorContainer"
                    android:padding="@dimen/spacing_small"
                    android:text="@string/notification_warning"
                    android:textColor="?attr/colorOnErrorContainer"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_medium"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_large"
                    android:text="@string/enable_notifications"
                    android:textAppearance="?attr/textAppearanceBodyLarge"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xsmall"
                    android:text="@string/reminder_time"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textSize="@dimen/text_body_medium"/>

                <TimePicker
                    android:id="@+id/timePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="@dimen/spacing_large"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xsmall"
                    android:text="@string/repeat"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textSize="@dimen/text_body_medium"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/frequencyGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/radioDaily"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/daily"
                        android:textSize="@dimen/text_button"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/radioWeekly"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/weekly"
                        android:textSize="@dimen/text_button"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:id="@+id/weeklyOptionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xsmall"
                        android:text="@string/week_day"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textSize="@dimen/text_body_medium"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/weekDayGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMonday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/monday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTuesday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/tuesday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWednesday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/wednesday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThursday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/thursday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFriday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/friday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaturday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/saturday_short"
                            android:textSize="@dimen/text_button"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSunday"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/sunday_short"
                            android:textSize="@dimen/text_button"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveButton"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:text="@string/save_settings"
                    android:textSize="@dimen/text_button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_notification"
                    android:textSize="@dimen/text_button"/>
            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>